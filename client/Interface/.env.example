# Copy to `client/Interface/.env.local` for local dev (`npm run dev`) or
# pass through `docker compose build --build-arg` for the production image.

# Bearer token sent on every state-bridge call. Must match
# STATE_BRIDGE_TOKEN in the bridge service env. The default below
# matches the docker-compose default and the integration-test default.
NEXT_PUBLIC_STATE_BRIDGE_TOKEN=integration-bridge-token

# Optional: override the bridge base URL. Defaults to `${origin}/bridge`,
# which Next rewrites to state-bridge:5003 for HTTP requests.
# NEXT_PUBLIC_STATE_BRIDGE_BASE=http://localhost:5003

# Optional: explicit bridge WebSocket base when bypassing the default
# `${protocol}://${hostname}:5003` resolution.
# NEXT_PUBLIC_STATE_BRIDGE_WS_BASE=ws://localhost:5003

# Optional: explicit engine WS URL when bypassing the bridge relay.
# NEXT_PUBLIC_ENGINE_WS_URL=ws://localhost:8080/ws

# Optional: turn off bridge command relay and talk to the engine directly.
# NEXT_PUBLIC_USE_BRIDGE_COMMANDS=false

# Optional: browser TTS provider selection.
# `browser` keeps using window.speechSynthesis.
# `fish_modal` calls the Go coaching proxy at /dashboard/tts.
NEXT_PUBLIC_TTS_PROVIDER=browser

# Optional: fallback provider when the primary TTS call fails.
# NEXT_PUBLIC_TTS_FALLBACK_PROVIDER=browser

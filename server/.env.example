# ============================================================
# Guided Chinese Chess - Environment Configuration Template
# .env.example
# ============================================================
# Copy to .env and fill in your values.
# The .env file is git-ignored; this template is committed.
# ============================================================

SERVER_HOST=0.0.0.0
SERVER_PORT=5000
ENGINE_WS_URL=ws://localhost:8080/ws

LLM_PROVIDER=mock

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_ANALYSIS_MODEL=
OPENROUTER_ORCHESTRATION_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=GuidedChineseChess
OPENROUTER_APP_URL=http://localhost:5000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_ANALYSIS_MODEL=
OPENAI_ORCHESTRATION_MODEL=

VLLM_BASE_URL=
VLLM_API_KEY=
VLLM_MODEL=
VLLM_ANALYSIS_MODEL=
VLLM_ORCHESTRATION_MODEL=

MODAL_LLM_BASE_URL=
MODAL_LLM_API_KEY=
MODAL_LLM_MODEL=
MODAL_LLM_ANALYSIS_MODEL=
MODAL_LLM_ORCHESTRATION_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

RAG_BACKEND=mock
CHROMA_DB_PATH=./chroma_db

LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=45

PROFILE_DIR=./agent_orchestration/.agent/profiles

LOG_LEVEL=INFO
